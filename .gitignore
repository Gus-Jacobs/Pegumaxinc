# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# ---- Django ----
# Local dev database — Render uses Postgres via DATABASE_URL, this is not needed there.
db.sqlite3
db.sqlite3-journal
# collectstatic output (regenerated on every Render build)
staticfiles/

# ---- Secrets / environment ----
.env
.env.*
!.env.example
*.pem
*.key

# ---- Archives / build artifacts (don't ship source zips) ----
*.zip
*.tar
*.tar.gz

# ---- User-uploaded media (served from storage, not the repo) ----
media/

# ---- Logs ----
*.log

# ---- Virtual environments ----
venv/
.venv/
env/
ENV/

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
.idea/
.vscode/
